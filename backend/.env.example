# Neon serverless Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/creo?sslmode=require

# Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# JSON array of allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:3000","https://yourcreo.com"]

# Demo rate limiting
DEMO_RATE_LIMIT_REQUESTS=3
DEMO_RATE_LIMIT_WINDOW_SECONDS=86400
